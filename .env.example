# ── 카카오 (developers.kakao.com) ─────────────────────────
# JavaScript 키: 지도 SDK용 (클라이언트 노출 OK, 콘솔에서 도메인 제한 필수)
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key
# REST API 키: 로컬(장소) 검색용 (서버 전용, 절대 클라이언트 노출 금지)
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # 서버 전용

# ── 보안 ─────────────────────────────────────────────────
IP_HASH_SALT=change_me_to_random_string            # IP 해시용 salt
ADMIN_SECRET=change_me_admin_password              # /admin 접근 비밀번호
